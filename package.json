{
  "name": "govspend.opendata.scot",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "start": "npm-run-all --parallel dev:*",
    "build": "run-s prod:*",
    "dev:eleventy": "eleventy --serve",
    "dev:parcel": "parcel watch ./_assets/js/main.js --dist-dir ./_site/assets --no-content-hash",
