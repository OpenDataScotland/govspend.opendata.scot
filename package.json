  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@parcel/transformer-sass": "^2.16.4",
    "cssnano": "^7.1.3",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.16.4",
    "postcss": "^8.5.8",
    "sass": "^1.98.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "highcharts": "^12.5.0",
    "lodash": "^4.17.23"
  }
}
